# Root env file for the dashboard/bootstrap process.
# Copy to `.env` and replace placeholders.

# Supabase control-plane and dashboard access.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=vivo-content

# Optional factory identity used during bootstrap.
VIVO_FACTORY_KEY=vivo-factory
VIVO_FACTORY_NAME=Vivo Factory

# Global LLM defaults used by setup checks, audience enrichment,
# and audience-manager launch.
# `LLM_PROVIDER` is optional when using OpenAI; it defaults to `openai`
# if `OPENAI_API_KEY` is present.
LLM_PROVIDER=openai
LLM_MODEL=replace-me
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=replace-me
